DJANGO_DEBUG=True
DJANGO_SECRET_KEY=cambia-esto-en-produccion-usa-una-clave-larga
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=proyecto
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306

# ── Email ──────────────────────────────────────────────────────────────────
# Para desarrollo local puedes usar el backend de consola (imprime en terminal):
#   EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Para producción con Gmail, genera una "Contraseña de aplicación" en:
#   https://myaccount.google.com/apppasswords
# y ponla aquí. NUNCA pongas tu contraseña real de Gmail.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tucorreo@gmail.com
EMAIL_HOST_PASSWORD=tu_contrasena_de_aplicacion
DEFAULT_FROM_EMAIL=tucorreo@gmail.com
EMAIL_TIMEOUT=10
